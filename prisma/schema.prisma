// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  VIEWER
}

enum WorkspacePlanType {
  PERSONAL
  ORG
}

enum WorkspacePlanStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceCapability {
  CORE_CRM
  PROPERTY_PIPELINE
  MESSAGING
  INTEGRATIONS
  ORG_MEMBERS
  ADVANCED_AUTOMATIONS
  ADVANCED_ANALYTICS
  AI_ASSIST
  SCREENING
  CALENDAR_SYNC
}

enum LeadStatus {
  NEW
  AWAITING_RESPONSE
  INCOMPLETE
  UNDER_REVIEW
  QUALIFIED
  CAUTION
  TOUR_SCHEDULED
  APPLICATION_SENT
  DECLINED
  ARCHIVED
  CLOSED
}

enum QualificationFit {
  UNKNOWN
  PASS
  CAUTION
  MISMATCH
}

enum LeadSourceType {
  MANUAL
  EMAIL
  SMS
  WEB_FORM
  CSV_IMPORT
  FACEBOOK
  ZILLOW
  SPAREROOM
  ROOMSTER
  CRAIGSLIST
  OTHER
}

enum ContactChannel {
  EMAIL
  SMS
  PHONE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageOrigin {
  INBOUND
  OUTBOUND_MANUAL
  OUTBOUND_AUTOMATED
  SYSTEM_NOTICE
}

enum DeclineReason {
  RULE_MISMATCH
  MISSING_INFO
  OPERATOR_DECISION
  NO_AVAILABILITY
  UNRESPONSIVE
  DUPLICATE
  WITHDREW
}

enum RuleCategory {
  SMOKING
  PETS
  GUESTS
  BATHROOM_SHARING
  PARKING
  MINIMUM_STAY
  WORK_SCHEDULE
  ACKNOWLEDGMENT
  GENERAL
}

enum RuleMode {
  BLOCKING
  WARNING_ONLY
  INFORMATIONAL
}

enum TourEventStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  RESCHEDULED
}

enum NotificationType {
  NEW_LEAD
  CAUTION_REVIEW
  MISMATCH_REVIEW
  STALE_LEAD
  TOUR_SCHEDULED
  APPLICATION_INVITE_STALE
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTER
}

enum AuditActorType {
  SYSTEM
  USER
}

enum MessageChannel {
  EMAIL
  SMS
  INTERNAL_NOTE
}

enum QuestionType {
  TEXT
  SELECT
  YES_NO
  NUMBER
  DATE
}

enum RuleSeverity {
  REQUIRED
  WARNING
  PREFERENCE
}

enum TemplateType {
  INITIAL_REPLY
  MISSING_INFO_FOLLOW_UP
  TOUR_CONFIRMATION
  APPLICATION_INVITE
  DECLINE
  REMINDER
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified Boolean      @default(false)
  name          String
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  billingOwnedWorkspaces Workspace[] @relation("WorkspaceBillingOwner")
  auditEvents   AuditEvent[] @relation("AuditActor")
  sentWorkspaceInvites     WorkspaceInvite[] @relation("WorkspaceInviteCreatedBy")
  acceptedWorkspaceInvites WorkspaceInvite[] @relation("WorkspaceInviteAcceptedBy")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Workspace {
  id                    String            @id @default(cuid())
  name                  String
  slug                  String            @unique
  planType              WorkspacePlanType   @default(PERSONAL)
  planStatus            WorkspacePlanStatus @default(TRIAL)
  billingOwnerUserId    String?
  enabledCapabilities   WorkspaceCapability[] @default([CORE_CRM, PROPERTY_PIPELINE, MESSAGING, INTEGRATIONS])
  onboardingCompletedAt DateTime?
  channelPriority       Json?
  dailyAutomatedSendCap Int               @default(3)
  webhookSigningSecret  String?
  billingOwner          User?             @relation("WorkspaceBillingOwner", fields: [billingOwnerUserId], references: [id], onDelete: SetNull)
  memberships           Membership[]
  workspaceInvites      WorkspaceInvite[]
  properties            Property[]
  leadSources           LeadSource[]
  leads                 Lead[]
  messageTemplates      MessageTemplate[]
  auditEvents           AuditEvent[]
  notifications         NotificationEvent[]
  usageSnapshots        WorkspaceUsageSnapshot[]
  webhookDeliveries     OutboundWebhookDelivery[]
  tours                 TourEvent[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([billingOwnerUserId])
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(OWNER)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model WorkspaceInvite {
  id               String         @id @default(cuid())
  workspaceId      String
  email            String
  role             MembershipRole
  tokenHash        String         @unique
  invitedByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?
  revokedAt        DateTime?
  expiresAt        DateTime
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedByUser    User           @relation("WorkspaceInviteCreatedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedByUser   User?          @relation("WorkspaceInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([workspaceId, createdAt])
  @@index([workspaceId, email])
  @@index([email, expiresAt])
}

model Property {
  id                  String                     @id @default(cuid())
  workspaceId         String
  name                String
  propertyType        String?
  addressLine1        String?
  locality            String?
  rentableRoomCount   Int?
  sharedBathroomCount Int?
  parkingAvailable    Boolean                    @default(false)
  smokingAllowed      Boolean                    @default(false)
  petsAllowed         Boolean                    @default(false)
  schedulingUrl       String?
  channelPriority     Json?
  schedulingEnabled   Boolean                    @default(false)
  workspace           Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rules               PropertyRule[]
  questionSets        QualificationQuestionSet[]
  leads               Lead[]
  auditEvents         AuditEvent[]
  tours               TourEvent[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([workspaceId])
}

model LeadSource {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  type        LeadSourceType @default(MANUAL)
  active      Boolean        @default(true)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads       Lead[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([workspaceId, name])
}

model Lead {
  id                      String                @id @default(cuid())
  workspaceId             String
  propertyId              String?
  leadSourceId            String?
  fullName                String
  email                   String?
  phone                   String?
  preferredContactChannel ContactChannel?
  moveInDate              DateTime?
  monthlyBudget           Int?
  stayLengthMonths        Int?
  workStatus              String?
  notes                   String?
  status                  LeadStatus            @default(NEW)
  fitResult               QualificationFit      @default(UNKNOWN)
  declineReason           DeclineReason?
  declinedAt              DateTime?
  isSoftDeclined          Boolean               @default(false)
  optOutAt                DateTime?
  optOutReason            String?
  isStale                 Boolean               @default(false)
  staleAt                 DateTime?
  staleReason             String?
  staleAutoArchiveBlocked Boolean               @default(false)
  applicationInviteSentAt DateTime?
  applicationInviteChannel MessageChannel?
  automatedSendCountDate  DateTime?
  automatedSendCount      Int                   @default(0)
  lastActivityAt          DateTime?
  workspace               Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property                Property?             @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  leadSource              LeadSource?           @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  contact                 Contact?
  conversation            Conversation?
  answers                 QualificationAnswer[]
  statusHistory           LeadStatusHistory[]
  auditEvents             AuditEvent[]          @relation("LeadAuditEvents")
  tours                   TourEvent[]
  notifications           NotificationEvent[]
  webhookDeliveries       OutboundWebhookDelivery[]
  fieldMetadata           Json?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([workspaceId, status])
  @@index([propertyId, status])
}

model Contact {
  id               String          @id @default(cuid())
  leadId           String          @unique
  email            String?
  phone            String?
  preferredChannel ContactChannel?
  lead             Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Conversation {
  id               String    @id @default(cuid())
  leadId           String    @unique
  subject          String?
  externalThreadId String?
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages         Message[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([externalThreadId])
}

model Message {
  id                String           @id @default(cuid())
  conversationId    String
  templateId        String?
  direction         MessageDirection
  origin            MessageOrigin      @default(SYSTEM_NOTICE)
  channel           MessageChannel
  body              String
  subject           String?
  deliveryStatus    String?
  stateSignature    String?
  renderedSnapshot  Json?
  externalMessageId String?
  externalThreadId  String?
  sentAt            DateTime?
  receivedAt        DateTime?
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template          MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@index([externalThreadId])
  @@index([channel, externalMessageId])
  @@index([stateSignature])
}

model QualificationQuestionSet {
  id         String                  @id @default(cuid())
  propertyId String
  name       String
  isDefault  Boolean                 @default(true)
  property   Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  questions  QualificationQuestion[]
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([propertyId])
}

model QualificationQuestion {
  id            String                   @id @default(cuid())
  questionSetId String
  label         String
  fieldKey      String
  type          QuestionType
  required      Boolean                  @default(true)
  sortOrder     Int                      @default(0)
  options       Json?
  questionSet   QualificationQuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  answers       QualificationAnswer[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([questionSetId, fieldKey])
  @@index([questionSetId, sortOrder])
}

model QualificationAnswer {
  id         String                @id @default(cuid())
  leadId     String
  questionId String
  value      Json
  lead       Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  question   QualificationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([leadId, questionId])
}

model PropertyRule {
  id          String       @id @default(cuid())
  propertyId  String
  label       String
  description String?
  category    String?
  ruleCategory RuleCategory @default(GENERAL)
  mode         RuleMode     @default(BLOCKING)
  active       Boolean      @default(true)
  severity    RuleSeverity @default(REQUIRED)
  autoDecline Boolean      @default(false)
  warningOnly Boolean      @default(false)
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([propertyId])
}

model MessageTemplate {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  type        TemplateType
  channel     MessageChannel
  subject     String?
  body        String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, type])
}

model LeadStatusHistory {
  id         String      @id @default(cuid())
  leadId     String
  fromStatus LeadStatus?
  toStatus   LeadStatus
  reason     String?
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@index([leadId, createdAt])
}

model AuditEvent {
  id          String    @id @default(cuid())
  workspaceId String
  leadId      String?
  propertyId  String?
  actorUserId String?
  actorType   AuditActorType @default(SYSTEM)
  eventType   String
  payload     Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead        Lead?     @relation("LeadAuditEvents", fields: [leadId], references: [id], onDelete: SetNull)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  actorUser   User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([leadId, createdAt])
}

model TourEvent {
  id                 String          @id @default(cuid())
  workspaceId        String
  leadId             String
  propertyId         String?
  status             TourEventStatus @default(SCHEDULED)
  scheduledAt        DateTime?
  canceledAt         DateTime?
  cancelReason       String?
  externalCalendarId String?
  previousTourEventId String?
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead               Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property           Property?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([workspaceId, status, createdAt])
  @@index([leadId, createdAt])
  @@index([propertyId, createdAt])
}

model NotificationEvent {
  id          String           @id @default(cuid())
  workspaceId String
  leadId      String?
  type        NotificationType
  title       String
  body        String
  readAt      DateTime?
  payload     Json?
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead        Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, type, createdAt])
  @@index([leadId, createdAt])
}

model OutboundWebhookDelivery {
  id            String                @id @default(cuid())
  workspaceId   String
  leadId        String?
  eventType     String
  destinationUrl String
  signature     String?
  payload       Json
  status        WebhookDeliveryStatus @default(PENDING)
  attemptCount  Int                   @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  lastError     String?
  deadLetteredAt DateTime?
  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead          Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([workspaceId, status, nextAttemptAt])
  @@index([leadId, createdAt])
}

model WorkspaceUsageSnapshot {
  id              String   @id @default(cuid())
  workspaceId     String
  snapshotDate    DateTime
  activeProperties Int
  monthlyLeads    Int
  automationSends Int
  seats           Int
  payload         Json?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@unique([workspaceId, snapshotDate])
  @@index([workspaceId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
